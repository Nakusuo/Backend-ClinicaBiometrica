# Para correr localmente con tu PostgreSQL local:
# DATABASE_URL=postgresql://postgres:admin@localhost:5432/telemedicina
# Para correr con Docker (el host es 'db' porque coincide con el nombre del servicio en docker-compose):
DATABASE_URL=postgresql://postgres:admin@db:5432/telemedicina
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin
POSTGRES_DB=telemedicina

SECRET_KEY=cambia-esto-por-una-clave-larga-y-secreta
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# En produccion coloca el dominio/IP del frontend.
# Ejemplo: CORS_ORIGINS=https://clinica.tudominio.com,http://TU_IP_PUBLICA
CORS_ORIGINS=*

# Token simple para que FreePBX/Asterisk envie webhooks al backend.
# Si lo configuras, debe enviarse en el header: X-Webhook-Token
ASTERISK_WEBHOOK_TOKEN=cambia-este-token

# MariaDB interna de FreePBX. Usar un usuario SOLO LECTURA.
FREEPBX_DB_HOST=ip_o_hostname_freepbx
FREEPBX_DB_PORT=3306
FREEPBX_DB_USER=telemedicina_ro
FREEPBX_DB_PASSWORD=cambia-esta-clave
FREEPBX_DB_NAME=asteriskcdrdb
